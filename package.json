{
  "name": "@playwright-mcp/server",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Playwright browser automation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "playwright-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "start": "node dist/cli.js",
    "test": "playwright test",
    "test:unit": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "mcp",
    "model-context-protocol",
    "browser-automation",
    "ai",
    "llm"
  ],
  "author": "playwright-mcp contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/playwright-mcp/playwright-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/playwright-mcp/playwright-mcp/issues"
  },
  "homepage": "https://github.com/playwright-mcp/playwright-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "playwright": "^1.48.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.0.0",
    "prettier": "^3.3.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.5.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/unit/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    }
  }
}
